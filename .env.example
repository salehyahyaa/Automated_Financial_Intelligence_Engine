# Copy to .env — do not commit real secrets.

# LOG_LEVEL=INFO

# API bind. Default PORT=8001 (python main.py + gunicorn_start.sh). Use HOST=0.0.0.0 in prod.
# HOST=0.0.0.0
# PORT=8001
# WEB_CONCURRENCY=2
# CORS_ALLOW_ORIGINS=https://your-frontend.example.com

# Any one of these (first non-empty wins). In the URI, encode special chars in the password (@ -> %40, # -> %23).
DATABASE_URL=
# POSTGRES_URL=
# SUPABASE_DATABASE_URL=
# Or discrete DB_* if not using a URI

# Supabase Auth (optional). bearer_required if SUPABASE_JWT_SECRET and/or SUPABASE_URL is set.
# HS256: set SUPABASE_JWT_SECRET (Legacy JWT secret). ES256 (new JWT signing keys): set SUPABASE_URL — API loads JWKS automatically; optional SUPABASE_JWKS_URL override.
# SUPABASE_JWT_SECRET=
# SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co   # or supabase-url=
# SUPABASE_ANON_KEY=eyJ...   # or supabase-anon-key=  (legacy anon / public; not service_role)
# SUPABASE_JWKS_URL=   # optional full JWKS URL if not default under SUPABASE_URL/auth/v1/.well-known/jwks.json

# Plaid (minimum: client id + secret + PLAID_ENV). Optional: products/countries/link user id.
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_PRODUCTS=transactions
# PLAID_COUNTRY_CODES=US
# PLAID_LINK_USER_ID=stable-per-user-when-you-have-auth

# OpenAI: use OPENAI_API_KEY or OPEN_AI_API_KEY; model must match your OpenAI dashboard id.
# OPENAI_API_KEY=
# OPEN_AI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
